# Server-side only (Next.js BFF → Nest API). Required in production/staging builds.
# Example: http://127.0.0.1:3000 when the API listens on 3000 and Next runs on 3001.
FARTS_API_BASE_URL=

# Optional: same secret as backend OPS_CONSOLE_SECRET — injected as x-ops-key by /api/ops/* BFF routes
# (e.g. /moderation-lab). You can also type the key in the lab UI instead.
# OPS_CONSOLE_SECRET=

# Optional: override analytics ingest URL. When unset, events POST to /api/analytics/events (BFF).
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=

# Optional: force analyze capture chamber to simulated mode (no microphone). Default is live.
# NEXT_PUBLIC_CAPTURE_MODE=simulated

# Homepage: omit or `false` = live product. `true` = pre-launch waitlist shell on /.
NEXT_PUBLIC_LAUNCH_MODE=false

# Staging checklist + API env (gallery, playback, ops): see frontend/LAUNCH.md
