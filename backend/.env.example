NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=farts
DATABASE_PASSWORD=farts
DATABASE_NAME=farts
DATABASE_SSL=false
DATABASE_RUN_MIGRATIONS=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Object storage (S3-compatible)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./.storage
STORAGE_BUCKET=farts-artifacts
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Queue
QUEUE_PROVIDER=memory

# AI (stub in Phase 1)
AI_PROVIDER=stub

# Anonymous sessions
SESSION_COOKIE_NAME=farts_session
SESSION_TTL_SECONDS=2592000

# Audio uploads
AUDIO_UPLOAD_MAX_BYTES=1048576
AUDIO_UPLOAD_ALLOWED_MIME_TYPES=audio/webm,audio/ogg,audio/mpeg
AUDIO_UPLOAD_STORAGE_PREFIX=audio/raw
