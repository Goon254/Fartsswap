NODE_ENV=production
PORT=3000

# Neon Postgres
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_SSL=true
DATABASE_RUN_MIGRATIONS=true

# Redis (Upstash, ElastiCache, etc.)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
QUEUE_PROVIDER=redis

# S3-compatible storage (AWS S3, R2, MinIO)
STORAGE_PROVIDER=s3
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=

# AI
AI_PROVIDER=openai
AI_ENABLED=true
AI_API_KEY=

SESSION_COOKIE_SECRET=
AUDIO_AUTO_DELETE_AFTER_PROCESSING=false
CORS_ALLOWED_ORIGINS=https://your-frontend.example
OPS_CONSOLE_SECRET=
FARTS_PUBLIC_ORIGIN=https://your-frontend.example

GALLERY_SUBMISSIONS_ENABLED=true
GALLERY_PUBLIC_FEED_ENABLED=true
FARTMAXIMIZER_ENABLED=true
APP_ROLE=all
