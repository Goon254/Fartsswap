NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=farts
DATABASE_PASSWORD=farts
DATABASE_NAME=farts
DATABASE_SSL=false
DATABASE_RUN_MIGRATIONS=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Object storage (S3-compatible)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./.storage
STORAGE_BUCKET=farts-artifacts
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Queue
QUEUE_PROVIDER=memory

# AI (stub in Phase 1)
# --- AI report orchestrator ---
# Provider: 'openai' (real OpenAI / OpenAI-compatible chat completions),
# 'disabled' / 'stub' (no network calls, always fallback to deterministic generator).
AI_PROVIDER=disabled
AI_ENABLED=false
# AI_API_KEY=sk-...
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=8000
AI_MAX_TOKENS=400
AI_TEMPERATURE=0.9
AI_MAX_RETRIES=1
# When true, structured (sanitized) AI debug logs are emitted via Pino at debug level.
# Never logs prompts or raw model output in product analytics regardless.
AI_DEBUG_LOG=false

# --- AI usage caps (per UTC day) ---
# Set either to 0 to disable that scope entirely. Quotas count every report
# orchestration attempt, including deterministic fallbacks, so a flood of bad
# input can't blow the budget. Counters reset at end of UTC day.
AI_DAILY_SESSION_LIMIT=50
AI_DAILY_IP_LIMIT=200

# Anonymous sessions
SESSION_COOKIE_NAME=farts_session
SESSION_TTL_SECONDS=2592000
# Required in production; >=32 chars. Used to sign anonymous session cookies.
SESSION_COOKIE_SECRET=

# Audio uploads
AUDIO_UPLOAD_MAX_BYTES=1048576
AUDIO_UPLOAD_ALLOWED_MIME_TYPES=audio/webm,audio/ogg,audio/mpeg
AUDIO_UPLOAD_STORAGE_PREFIX=audio/raw
AUDIO_AUTO_DELETE_AFTER_PROCESSING=false

# Security / rate limiting
# Comma-separated origins, or '*' to allow any (dev only).
CORS_ALLOWED_ORIGINS=*
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_SECONDS=60
REQUEST_BODY_LIMIT_BYTES=131072

# Idempotency cache TTL for replayed POST responses
IDEMPOTENCY_TTL_SECONDS=86400

# --- Process role ---
# 'api' = HTTP only, 'worker' = background only, 'all' = both (dev/single-instance).
APP_ROLE=all

# --- Graceful shutdown ---
SHUTDOWN_GRACE_SECONDS=15

# --- Observability ---
METRICS_ENABLED=true
METRICS_PATH=/metrics
# OpenTelemetry traces (HTTP + DB + Redis). Disabled by default — set to true
# and configure an OTLP HTTP endpoint to enable.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=farts-backend
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# Sentry / error reporting (no-op when unset)
# SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Outbox dispatcher (worker) ---
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=10

# --- Audio retention (worker) ---
# Hard delete raw audio older than this, regardless of per-flow auto-delete.
# Set to 0 to disable. Default: 24h.
AUDIO_RETENTION_MAX_AGE_HOURS=24
AUDIO_RETENTION_SWEEP_INTERVAL_MS=60000
